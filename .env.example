# ============================================================
# Kite ML Trading Pipeline — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Zerodha Kite Connect ---
# Get from: https://kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=                   # Set after running: python -m ingestion.kite_auth

# --- QuestDB ---
QUESTDB_HOST=localhost
QUESTDB_ILP_PORT=9000
QUESTDB_PG_PORT=8812
QUESTDB_USERNAME=admin
QUESTDB_PASSWORD=quest

# --- App ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_PAPER_TRADING=true               # IMPORTANT: set to false only after validating ML model

# --- ML ---
ML_FEATURE_WINDOW_SECONDS=30
ML_PREDICTION_HORIZON_SECONDS=60
ML_SIGNAL_CONFIDENCE_THRESHOLD=0.65
ML_RETRAIN_INTERVAL_MINUTES=30
ML_MODEL_DIR=models/saved
ML_MLFLOW_TRACKING_URI=http://localhost:5000

# --- Kite Instrument Config ---
KITE_OPTION_STRIKES_RANGE=10         # ATM ± 10 strikes
KITE_OPTION_EXPIRIES=2               # Current + next weekly expiry
